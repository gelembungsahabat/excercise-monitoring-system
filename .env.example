# FitTrack AI – environment variables
# Copy to .env for local development (never commit .env to git)

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: override the default AI model
# Default: google/gemini-2.0-flash-001
# Other good options:
#   meta-llama/llama-3.1-8b-instruct:free  (free tier)
#   mistralai/mistral-7b-instruct:free      (free tier)
#   openai/gpt-4o-mini                      (fast + cheap)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Port for the FastAPI server (Railway sets this automatically)
PORT=8000
